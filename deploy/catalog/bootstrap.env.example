# Credentials: uploads use Application Default Credentials (ADC). If GOOGLE_APPLICATION_CREDENTIALS
# points at a service-account JSON, THAT account must have storage.objects.create on BUCKET (and
# Firestore write on PROJECT_ID). A 403 with another project's SA means: unset that env var and run
#   gcloud config set project <project-that-owns-the-bucket>
#   gcloud auth application-default login
# or grant roles/storage.objectCreator on gs://$BUCKET to that service account.

PROJECT_ID=my-project-chat-ai-487408
BUCKET=my-project-chat-ai-487408-mcart-catalog-images
# Region for create_catalog_bucket.sh (e.g. ASIA-SOUTH2)
BUCKET_LOCATION=ASIA-SOUTH2
FIRESTORE_LOCATION=asia-south2

CATALOG_BOOTSTRAP_MEMBER=serviceAccount:my-sa@PROJECT_ID.iam.gserviceaccount.com
# CATALOG_BOOTSTRAP_SA_EMAIL=my-sa@PROJECT_ID.iam.gserviceaccount.com
SKIP_CATALOG_IAM=false   # only create/verify Firestore, do not change IAM
# Set true so browsers can load image URLs without signed URLs (demo only)
CATALOG_BUCKET_PUBLIC_READ=true

# Optional overrides (paths relative to deploy/, not your shell cwd)
CATALOG_JSON=catalog/products.json
CATALOG_ASSETS_DIR=catalog/assets
IMAGE_PREFIX=products
FIRESTORE_COLLECTION=products
FORCE_UPLOAD=false

# Optional reindex trigger
# REINDEX_URL=https://mcart.space/product-indexer/admin/reindex
# MCART_BEARER_TOKEN=<jwt-with-reindex-scope>

