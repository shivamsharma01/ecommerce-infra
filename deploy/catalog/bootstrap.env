PROJECT_ID=my-project-chat-ai-487408
BUCKET=my-project-chat-ai-487408-mcart-catalog-images
# Region for create_catalog_bucket.sh (e.g. ASIA-SOUTH2)
BUCKET_LOCATION=ASIA-SOUTH2
# Set true so browsers can load image URLs without signed URLs (demo only)
CATALOG_BUCKET_PUBLIC_READ=true

# Optional overrides (paths relative to deploy/, not your shell cwd)
CATALOG_JSON=catalog/products.json
CATALOG_ASSETS_DIR=catalog/assets
IMAGE_PREFIX=products
FIRESTORE_COLLECTION=products
FORCE_UPLOAD=false

# Optional reindex trigger
# REINDEX_URL=https://mcart.space/product-indexer/admin/reindex
# MCART_BEARER_TOKEN=<jwt-with-reindex-scope>

