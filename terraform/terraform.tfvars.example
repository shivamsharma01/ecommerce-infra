# Copy to terraform.tfvars (gitignored) and edit.
#
# Before first apply: ./scripts/enable-apis.sh <project_id>  (see README §1)

project_id = "ecommerce-491019"
region     = "asia-south2"

regional_cluster  = false
zone              = "asia-south2-a"
node_machine_type = "e2-highmem-4"
node_min_count    = 2
node_max_count    = 3
node_disk_size_gb = 120
node_preemptible  = true

# Ingress should use the reserved global static IP via annotation:
#   kubernetes.io/ingress.global-static-ip-name: mcart-public-ip

# Optional Workload Identity bindings (uncomment and set real SA emails):
# workload_service_accounts = {
#   auth            = "mcart-auth@ecommerce-491019.iam.gserviceaccount.com"
#   user            = "mcart-user@ecommerce-491019.iam.gserviceaccount.com"
#   product         = "mcart-product@ecommerce-491019.iam.gserviceaccount.com"
#   product_indexer = "mcart-product-indexer@ecommerce-491019.iam.gserviceaccount.com"
# }

# Optional Cloud DNS in GCP (delegate NS at registrar):
# create_cloud_dns_public_zone = true

# Pre-created catalog bucket (recommended for demo stability):
# catalog_images_bucket_name = "ecommerce-491019-mcart-catalog-images"
