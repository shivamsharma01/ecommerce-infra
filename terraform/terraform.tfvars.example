# Copy to terraform.tfvars (gitignored) and edit.

project_id = "ecommerce-491019"
region     = "asia-south2"

regional_cluster  = false
zone              = "asia-south2-a"
node_machine_type = "e2-highmem-4"
node_min_count    = 2
node_max_count    = 3
node_disk_size_gb = 120
node_preemptible  = true

# After: kubectl get ingress mcart-store -n mcart — set HTTPS origin, bump api_gateway_config_id, re-apply.
# ingress_https_backend_base_url = "https://YOUR_INGRESS_IP_OR_HOST"
# api_gateway_config_id          = "v2"

